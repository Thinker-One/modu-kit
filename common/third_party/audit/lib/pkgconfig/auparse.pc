prefix=/root/zhn/audit-userspace-2.8/local_install
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include

Name: libauparse
Description: Library for apps that want to parse and interpret audit events
Version: 2.8
Libs: -L${libdir} -lauparse
Libs.private: -laudit
Cflags: -I${includedir}
